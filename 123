-- === PHẦN 1: AUTO KEY (CŨ) ===

-- Hàm xử lý vòng lặp nhấn phím
local function CreateAutoKey(key)
    task.spawn(function()
        while true do
            if Options["Auto" .. key] and Options["Auto" .. key].Value then
                Vim:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                task.wait(0.05) -- Thời gian nhấn giữ
                Vim:SendKeyEvent(false, Enum.KeyCode[key], false, game)
            end
            task.wait(0.1) -- Khoảng cách giữa mỗi lần bấm
        end
    end)
end

-- Tạo các nút gạt (Toggle) cho từng phím ở Tab Main
Tabs.Main:AddParagraph({
    Title = "Cài đặt phím",
    Content = "Bật các phím bạn muốn tự động nhấn liên tục."
})

for _, key in ipairs(Keys) do
    Options["Auto" .. key] = Tabs.Main:AddToggle("Auto" .. key, {Title = "Tự động bấm phím " .. key, Default = false })
    CreateAutoKey(key)
end


