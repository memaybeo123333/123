local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local Vim = game:GetService("VirtualInputManager")

local Window = Fluent:CreateWindow({
    Title = "Auto Key Menu",
    SubTitle = "by Gemini",
    TabWidth = 160,
    Size = UDim2.fromOffset(450, 320),
    Acrylic = true,
    Theme = "Dark"
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "keyboard" })
}

local Options = {}
local Keys = {"Z", "X", "C", "V", "F"}

-- Hàm xử lý vòng lặp nhấn phím
local function CreateAutoKey(key)
    task.spawn(function()
        while true do
            if Options["Auto" .. key] and Options["Auto" .. key].Value then
                Vim:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                task.wait(0.05) -- Thời gian nhấn giữ
                Vim:SendKeyEvent(false, Enum.KeyCode[key], false, game)
            end
            task.wait(0.1) -- Khoảng cách giữa mỗi lần bấm
        end
    end)
end

-- Tạo các nút gạt (Toggle) cho từng phím
Tabs.Main:AddParagraph({
    Title = "Cài đặt phím",
    Content = "Bật các phím bạn muốn tự động nhấn liên tục."
})

for _, key in ipairs(Keys) do
    Options["Auto" .. key] = Tabs.Main:AddToggle("Auto" .. key, {Title = "Tự động bấm phím " .. key, Default = false })
    
    Options["Auto" .. key]:OnChanged(function()
        print("Trạng thái phím " .. key .. ":", Options["Auto" .. key].Value)
    end)
    
    CreateAutoKey(key)
end

Window:SelectTab(1)
Fluent:Notify({
    Title = "Thành công",
    Content = "Menu đã được tải xong!",
    Duration = 5
})
