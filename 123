local Options = {}

-- === PHẦN 1: AUTO KEY ===
local Keys = {"Z", "X", "C", "V", "F"}

local function CreateAutoKey(key)
    task.spawn(function()
        while true do
            if Options["Auto" .. key] and Options["Auto" .. key].Value then
                Vim:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                task.wait(0.05)
                Vim:SendKeyEvent(false, Enum.KeyCode[key], false, game)
            end
            task.wait(0.1)
        end
    end)
end

for _, key in ipairs(Keys) do
    Options["Auto" .. key] = Tabs.Main:AddToggle("Auto" .. key, {Title = "Tự động bấm phím " .. key, Default = false })
    CreateAutoKey(key)
end

