local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local Vim = game:GetService("VirtualInputManager")

local Window = Fluent:CreateWindow({
    Title = "Auto Key Menu",
    SubTitle = "by Gemini",
    TabWidth = 160,
    Size = UDim2.fromOffset(450, 320),
    Acrylic = true,
    Theme = "Dark"
})

local Tabs = {
    Main = Window:AddTab({ Title = "Cài Đặt Phím", Icon = "keyboard" })
}

local Options = {}
local Keys = {"Z", "X", "C", "V", "F"}

-- Hàm xử lý vòng lặp nhấn phím độc lập cho từng phím
local function CreateAutoKey(key)
    task.spawn(function()
        while true do
            -- Kiểm tra xem Toggle của phím này có đang bật không
            if Options["Auto" .. key] and Options["Auto" .. key].Value then
                Vim:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                task.wait(0.05) -- Thời gian giữ phím (giây)
                Vim:SendKeyEvent(false, Enum.KeyCode[key], false, game)
            end
            task.wait(0.1) -- Khoảng cách giữa các lần bấm (0.1 giây = 10 lần/giây)
        end
    end)
end

-- Tạo giao diện và kích hoạt vòng lặp
Tabs.Main:AddParagraph({
    Title = "Hướng dẫn",
    Content = "Bật công tắc để tự động spam phím tương ứng. Mỗi phím hoạt động riêng biệt."
})

for _, key in ipairs(Keys) do
    Options["Auto" .. key] = Tabs.Main:AddToggle("Auto" .. key, {
        Title = "Tự động bấm phím " .. key, 
        Default = false 
    })
    
    -- Khởi chạy vòng lặp cho phím này
    CreateAutoKey(key)
end

-- Thông báo khi chạy script thành công
Window:SelectTab(1)
Fluent:Notify({
    Title = "Hệ Thống",
    Content = "Menu Auto Key đã sẵn sàng!",
    Duration = 5
})
